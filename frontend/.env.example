# ======================
# Application Configuration
# ======================
NODE_ENV=development
APP_PORT=3000
API_PREFIX=api

# ======================
# JWT Authentication
# ======================
JWT_SECRET=change-me-in-production-use-strong-random-secret-key
JWT_EXPIRES_IN=1d

# ======================
# Mail Encryption
# ======================
# Required for encrypting mail account credentials
# Generate a strong random key (32+ characters recommended)
MAIL_ENCRYPTION_KEY=your-strong-random-encryption-key-change-this-in-production

# ======================
# Database Configuration
# ======================
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=moustafa
DB_PASSWORD=StrongPassword123!
DB_DATABASE=moustafa_skillers
DB_CHARSET=utf8mb4

# ======================
# WebSocket Management
# ======================
WS_MANAGE_TOKEN=your-websocket-management-token

# ======================
# Base Host (for generating URLs)
# ======================
BASE_HOST=http://localhost:3000
